# Telegram Bot Token (dari @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Anthropic API Key (dari console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Jumlah clip yang di-generate (default: 3)
MAX_CLIPS=3

# Durasi maksimum per clip dalam detik (default: 60)
MAX_CLIP_DURATION=60

# Durasi minimum per clip dalam detik (default: 15)
MIN_CLIP_DURATION=15

# Direktori temporary untuk video
TEMP_DIR=./tmp

# Path ke whisper binary (default: ./venv/bin/whisper)
# Tidak perlu diubah kalau install whisper di venv project
# WHISPER_BIN=./venv/bin/whisper

# Gradio Whisper API URL (fallback ke-2 setelah YouTube Captions)
# Default: hosted Whisper Large V3
# GRADIO_WHISPER_URL=https://5ye5ukld3vozxjuved6uxaxd5ueqepmh5fwb4lgbjiue.node.k8s.prd.nos.ci
